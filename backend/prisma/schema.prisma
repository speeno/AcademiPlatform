generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUM ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  INSTRUCTOR
  OPERATOR
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  DORMANT
  SUSPENDED
}

enum CourseStatus {
  DRAFT
  UPCOMING
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  REVIEWING
  SCHEDULED
  PUBLISHED
  HIDDEN
  ENDED
}

enum LessonType {
  VIDEO_YOUTUBE
  VIDEO_UPLOAD
  DOCUMENT
  TEXT
  LIVE_LINK
  QUIZ
}

enum EncodingStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum DrmType {
  NONE
  AES128
  PALLYCON
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

enum AssignmentSubmissionStatus {
  PENDING
  SUBMITTED
  REVIEWING
  FEEDBACK_DONE
}

enum ExamSessionStatus {
  UPCOMING
  OPEN
  CLOSED
  CANCELLED
}

enum ExamApplicationStatus {
  TEMP_SAVED
  PAYMENT_PENDING
  APPLIED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
}

enum ExamMode {
  OFFLINE
  ONLINE
  HYBRID
}

enum ExamEligibilityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SHORT_TEXT
  FILE_SUBMISSION
}

enum QuestionDifficulty {
  EASY
  NORMAL
  HARD
}

enum ExamPaperStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExamAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_GRADED
  MANUAL_GRADING
  GRADED
  INVALIDATED
}

enum ExamAnswerStatus {
  DRAFT
  SUBMITTED
  AUTO_GRADED
  MANUAL_GRADED
}

enum ExamResultStatus {
  PENDING
  PASSED
  FAILED
  INVALIDATED
}

enum ExamProctorEventType {
  HEARTBEAT
  HEARTBEAT_MISSED
  TAB_BLUR
  WINDOW_FOCUS_LOST
  FULLSCREEN_EXIT
  COPY_ATTEMPT
  PASTE_ATTEMPT
  CONTEXT_MENU
  WEBCAM_PERMISSION_DENIED
  WEBCAM_SNAPSHOT
  NETWORK_RECONNECT
  FORCE_SUBMIT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentTarget {
  ENROLLMENT
  EXAM_APPLICATION
  TEXTBOOK
}

enum DiscountType {
  NONE
  PERCENT
  FIXED
}

enum PriceTargetType {
  COURSE
  EXAM_SESSION
  TEXTBOOK
}

enum TextbookStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TextbookGrantedBy {
  ENROLLMENT
  PURCHASE
  ADMIN
}

enum BookVoucherCodeStatus {
  AVAILABLE
  ASSIGNED
  USED
}

enum NoticeScope {
  GLOBAL
  COURSE
}

enum InquiryStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum QnaQuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum IntroPageStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  SCHEDULED
}

enum CmsContentType {
  VIDEO_MP4
  VIDEO_YOUTUBE
  DOCUMENT
  HTML
  COURSE_PACKAGE
}

enum CmsContentStatus {
  DRAFT
  REVIEW_REQUESTED
  REJECTED
  PUBLISHED
  ARCHIVED
}

enum CmsCollaboratorRole {
  EDITOR
  ASSISTANT
}

enum CmsReviewStatus {
  REVIEW_REQUESTED
  APPROVED
  REJECTED
}

enum TrainingProgramStatus {
  DRAFT       // 계획
  RECRUITING  // 모집중
  IN_PROGRESS // 진행중
  COMPLETED   // 종료
  CANCELLED   // 취소
}

enum TrainingParticipantStatus {
  REGISTERED // 등록
  COMPLETED  // 수료
  DROPPED    // 중도포기
}

enum TrainingAttendanceStatus {
  PRESENT // 출석
  ABSENT  // 결석
  LATE    // 지각
  EXCUSED // 공결
}

enum TrainingCertificateStatus {
  ISSUED
  REVOKED
}

// ─── 사용자 ──────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  nameEn       String?
  phone        String?
  birthDate    DateTime?
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  mfaSecret    String?
  // 큐미 챗봇이 개인 학습 데이터(점수·일정·진도)를 외부 LLM(OpenAI) 프롬프트에 포함해도
  // 되는지에 대한 명시적 동의. 기본 false → 동의 전에는 개인정보가 서버 밖으로 나가지 않는다.
  qmiPersonalConsent Boolean @default(false)
  // 토큰 무효화 버전. access/refresh 토큰 payload 의 tv 와 비교해 불일치 시 거부한다.
  // 로그아웃·비밀번호 변경 시 증가시키면 해당 사용자의 모든 발급 토큰이 즉시 무효화된다.
  tokenVersion Int      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  enrollments         Enrollment[]
  lessonProgresses    LessonProgress[]
  assignmentSubmissions AssignmentSubmission[]
  examApplications    ExamApplication[]
  payments            Payment[]
  inquiries           Inquiry[]
  textbookAccesses    TextbookAccess[]
  textbookViewLogs    TextbookViewLog[]
  videoPlaySessions   VideoPlaySession[]
  qnaQuestions        QnaQuestion[]
  qnaAnswers          QnaAnswer[]
  assignedQnaQuestions QnaQuestion[] @relation("QnaAssignedInstructor")
  createdCourses      Course[]      @relation("CourseInstructor")
  cmsOwnedCourses     Course[]      @relation("CourseCmsOwner")
  cmsCollaborations   CourseCmsCollaborator[] @relation("CourseCmsCollaboratorUser")
  cmsGrantedCollaborations CourseCmsCollaborator[] @relation("CourseCmsCollaboratorGrantedBy")
  cmsContentItemsCreated ContentItem[] @relation("ContentItemCreatedBy")
  cmsContentItemsUpdated ContentItem[] @relation("ContentItemUpdatedBy")
  cmsContentVersionsCreated ContentVersion[] @relation("ContentVersionCreatedBy")
  cmsContentAssetsUploaded ContentAsset[] @relation("ContentAssetUploadedBy")
  cmsReviewRequestsRequested ContentReviewRequest[] @relation("ContentReviewRequestedBy")
  cmsReviewRequestsReviewed ContentReviewRequest[] @relation("ContentReviewReviewedBy")
  cmsContentAudits   ContentAuditLog[] @relation("ContentAuditActor")
  createdTextbooks    Textbook[]    @relation("TextbookCreator")
  bookVoucherGrants   BookVoucherGrant[]
  instructorPosts     InstructorPost[]
  auditLogs           AuditLog[]
  approvedExamApplications ExamApplication[] @relation("ExamApplicationApprovedBy")
  examAttempts        ExamAttempt[]
  gradedExamAnswers   ExamAnswer[] @relation("ExamAnswerGradedBy")
  publishedExamResults ExamResult[] @relation("ExamResultPublishedBy")
  trainingPermission         TrainingPermission?   @relation("TrainingPermissionUser")
  grantedTrainingPermissions TrainingPermission[]  @relation("TrainingPermissionGrantedBy")
  ownedTrainingPrograms      TrainingProgram[]     @relation("TrainingProgramOwner")
  trainingParticipations     TrainingParticipant[] @relation("TrainingParticipantUser")
  checkedTrainingAttendances TrainingAttendance[]  @relation("TrainingAttendanceCheckedBy")
  issuedTrainingCertificates TrainingCertificate[] @relation("TrainingCertificateIssuedBy")

  @@index([email])
  @@index([role, status])
}

// ─── 소개 페이지 CMS ─────────────────────────────────────────────────────────

model IntroPage {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  summary     String?
  ogTitle     String?
  ogDescription String?
  ogImage     String?
  status      IntroPageStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?
  updatedBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  sections    IntroPageSection[]

  @@index([slug, status])
}

model IntroPageSection {
  id          String   @id @default(cuid())
  pageId      String
  sectionType String
  title       String?
  contentJson Json
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  page        IntroPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, sortOrder])
}

// ─── 교육과정 ─────────────────────────────────────────────────────────────────

model Course {
  id                  String       @id @default(cuid())
  title               String
  slug                String       @unique
  description         String?
  summary             String?
  thumbnailUrl        String?
  price               Int          @default(0)
  currency            String       @default("KRW")
  basePrice           Int          @default(0)
  salePrice           Int?
  discountType        DiscountType @default(NONE)
  discountValue       Int          @default(0)
  priceValidFrom      DateTime?
  priceValidUntil     DateTime?
  pricePolicyVersion  Int          @default(1)
  category            String?
  tags                String[]
  instructorId        String
  cmsOwnerId          String?
  enrollmentStartAt   DateTime?
  enrollmentEndAt     DateTime?
  learningPeriodDays  Int?
  maxCapacity         Int?
  status              CourseStatus @default(DRAFT)
  isFeatured          Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  instructor          User         @relation("CourseInstructor", fields: [instructorId], references: [id])
  cmsOwner            User?        @relation("CourseCmsOwner", fields: [cmsOwnerId], references: [id])
  modules             CourseModule[]
  cmsCollaborators    CourseCmsCollaborator[]
  contentItems        ContentItem[]
  enrollments         Enrollment[]
  assignments         Assignment[]
  notices             Notice[]
  qnaQuestions        QnaQuestion[]
  courseTextbooks     CourseTextbook[]
  voucherCampaigns    BookVoucherCampaign[]
  voucherGrants       BookVoucherGrant[]
  trainingPrograms    TrainingProgram[]

  @@index([slug])
  @@index([status, category])
}

model CourseModule {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@index([courseId, sortOrder])
}

model Lesson {
  id            String        @id @default(cuid())
  courseId      String
  moduleId      String?
  title         String
  description   String?
  lessonType    LessonType
  contentStatus ContentStatus @default(DRAFT)
  isPreview     Boolean       @default(false)
  isLocked      Boolean       @default(false)
  releaseAt     DateTime?
  sortOrder     Int           @default(0)
  prerequisiteId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  module        CourseModule? @relation(fields: [moduleId], references: [id])
  videoAsset    LessonVideoAsset?
  documents     LessonDocument[]
  contentItem   ContentItem?
  progresses    LessonProgress[]
  versions      LessonVersion[]

  @@index([courseId, sortOrder])
  @@index([moduleId])
}

model LessonVideoAsset {
  id             String         @id @default(cuid())
  lessonId       String         @unique
  sourceType     String
  youtubeUrl     String?
  videoFileUrl   String?
  hlsPlaylistUrl String?
  s3OriginalKey  String?
  aesKeyId       String?
  thumbnailUrl   String?
  durationSeconds Int?
  subtitleUrl    String?
  embedEnabled   Boolean        @default(true)
  encodingStatus EncodingStatus @default(PENDING)
  drmType        DrmType        @default(NONE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  lesson         Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonDocument {
  id        String   @id @default(cuid())
  lessonId  String
  fileUrl   String
  fileName  String
  fileType  String
  fileSize  Int?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonVersion {
  id          String   @id @default(cuid())
  lessonId    String
  versionNo   Int
  changeNote  String?
  snapshotJson Json
  publishedBy String?
  publishedAt DateTime @default(now())

  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, versionNo])
}

model CourseCmsCollaborator {
  id          String              @id @default(cuid())
  courseId    String
  userId      String
  role        CmsCollaboratorRole @default(EDITOR)
  grantedById String?
  createdAt   DateTime            @default(now())

  course      Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User                @relation("CourseCmsCollaboratorUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User?               @relation("CourseCmsCollaboratorGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([courseId, userId])
  @@index([userId, createdAt])
}

model ContentItem {
  id                String           @id @default(cuid())
  courseId          String
  lessonId          String           @unique
  contentType       CmsContentType
  status            CmsContentStatus @default(DRAFT)
  latestVersionNo   Int              @default(0)
  publishedVersionNo Int?
  createdById       String
  updatedById       String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  course            Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson            Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdBy         User             @relation("ContentItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User             @relation("ContentItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  versions          ContentVersion[]
  assets            ContentAsset[]
  reviewRequests    ContentReviewRequest[]
  auditLogs         ContentAuditLog[]

  @@index([courseId, status])
}

model ContentVersion {
  id          String   @id @default(cuid())
  itemId      String
  versionNo   Int
  schemaJson  Json
  changeNote  String?
  createdById String
  createdAt   DateTime @default(now())

  item        ContentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ContentVersionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assets      ContentAsset[]
  reviewRequests ContentReviewRequest[]

  @@unique([itemId, versionNo])
  @@index([itemId, createdAt])
}

model ContentAsset {
  id          String   @id @default(cuid())
  itemId      String
  versionId   String?
  assetType   String
  mimeType    String
  storageKey  String?
  publicUrl   String?
  fileName    String?
  fileSize    Int?
  metaJson    Json?
  uploadedById String?
  createdAt   DateTime @default(now())

  item        ContentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  version     ContentVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  uploadedBy  User?       @relation("ContentAssetUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
}

model ContentReviewRequest {
  id            String          @id @default(cuid())
  itemId         String
  versionId      String?
  requestedById  String
  status         CmsReviewStatus @default(REVIEW_REQUESTED)
  reviewedById   String?
  reviewedAt     DateTime?
  rejectReason   String?
  createdAt      DateTime        @default(now())

  item           ContentItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  version        ContentVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  requestedBy    User            @relation("ContentReviewRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy     User?           @relation("ContentReviewReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([itemId, createdAt])
}

model ContentAuditLog {
  id          String   @id @default(cuid())
  itemId       String
  actorId      String?
  action       String
  payloadJson  Json?
  createdAt    DateTime @default(now())

  item         ContentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  actor        User?       @relation("ContentAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
  @@index([action, createdAt])
}

// ─── 동영상 재생 세션 (복제 방지) ─────────────────────────────────────────────

model VideoPlaySession {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  sessionToken String   @unique
  startedAt    DateTime @default(now())
  lastPingAt   DateTime @default(now())
  expiredAt    DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([sessionToken])
}

// ─── 수강 등록 ───────────────────────────────────────────────────────────────

model Enrollment {
  id           String           @id @default(cuid())
  userId       String
  courseId     String
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime         @default(now())
  expiresAt    DateTime?
  progressRate Float            @default(0)
  paymentId    String?

  user         User             @relation(fields: [userId], references: [id])
  course       Course           @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId, status])
}

// ─── 학습 진도 ───────────────────────────────────────────────────────────────

model LessonProgress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  status         String   @default("NOT_STARTED")
  watchedSeconds Int      @default(0)
  completionRate Float    @default(0)
  isCompleted    Boolean  @default(false)
  completedAt    DateTime?
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

// ─── 과제 ────────────────────────────────────────────────────────────────────

model Assignment {
  id             String   @id @default(cuid())
  courseId       String
  title          String
  description    String?
  dueAt          DateTime?
  allowResubmit  Boolean  @default(false)
  allowLateSubmit Boolean @default(false)
  maxFileSizeMb  Int      @default(50)
  allowedFileTypes String[]
  createdAt      DateTime @default(now())

  course         Course   @relation(fields: [courseId], references: [id])
  submissions    AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String                     @id @default(cuid())
  assignmentId String
  userId       String
  textAnswer   String?
  fileUrl      String?
  fileName     String?
  status       AssignmentSubmissionStatus @default(PENDING)
  submittedAt  DateTime                   @default(now())
  feedback     String?
  feedbackAt   DateTime?

  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([assignmentId, userId])
}

// ─── 시험 접수 ───────────────────────────────────────────────────────────────

model ExamSession {
  id                String            @id @default(cuid())
  qualificationName String
  roundName         String
  applyStartAt      DateTime
  applyEndAt        DateTime
  examAt            DateTime
  place             String?
  fee               Int               @default(0)
  currency          String            @default("KRW")
  basePrice         Int               @default(0)
  salePrice         Int?
  discountType      DiscountType      @default(NONE)
  discountValue     Int               @default(0)
  priceValidFrom    DateTime?
  priceValidUntil   DateTime?
  pricePolicyVersion Int              @default(1)
  capacity          Int?
  status            ExamSessionStatus @default(UPCOMING)
  guidanceHtml      String?
  relatedCourseId   String?
  examMode          ExamMode          @default(OFFLINE)
  examWindowStart   DateTime?
  examWindowEnd     DateTime?
  durationMinutes   Int?
  lateEntryMinutes  Int               @default(0)
  requireFullscreen Boolean           @default(false)
  requireWebcam     Boolean           @default(false)
  passingScore      Int               @default(60)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  applications      ExamApplication[]
  papers            ExamPaper[]
  attempts          ExamAttempt[]
}

model ExamApplication {
  id              String                @id @default(cuid())
  examSessionId   String
  userId          String?
  status          ExamApplicationStatus @default(TEMP_SAVED)
  formJson        Json
  idPhoto         Bytes?
  idPhotoMimeType String?
  idPhotoFileName String?
  idPhotoSize     Int?
  referrerCode    String?
  paymentId       String?
  paymentStatus   PaymentStatus         @default(PENDING)
  examEligibility ExamEligibilityStatus  @default(PENDING)
  approvedAt      DateTime?
  approvedById    String?
  appliedAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  examSession     ExamSession @relation(fields: [examSessionId], references: [id])
  user            User?       @relation(fields: [userId], references: [id])
  approvedBy      User?       @relation("ExamApplicationApprovedBy", fields: [approvedById], references: [id])
  attempts        ExamAttempt[]

  @@index([examSessionId, status])
  @@index([examEligibility])
  @@index([userId])
}

model QuestionBank {
  id          String   @id @default(cuid())
  title       String
  description String?
  qualificationName String?
  subject     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   Question[]

  @@index([qualificationName, subject])
  @@index([isActive])
}

model Question {
  id          String             @id @default(cuid())
  bankId      String
  type        QuestionType
  difficulty  QuestionDifficulty @default(NORMAL)
  prompt      String
  explanation String?
  points      Int                @default(1)
  tags        String[]
  version     Int                @default(1)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  bank        QuestionBank       @relation(fields: [bankId], references: [id], onDelete: Cascade)
  options     QuestionOption[]
  answerKeys  QuestionAnswerKey[]
  paperItems  ExamPaperItem[]
  answers     ExamAnswer[]

  @@index([bankId, type, isActive])
  @@index([difficulty])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  label      String
  text       String
  order      Int      @default(0)

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
}

model QuestionAnswerKey {
  id           String   @id @default(cuid())
  questionId   String
  optionId     String?
  textPattern   String?
  points       Int      @default(1)
  explanation  String?

  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model ExamPaper {
  id            String          @id @default(cuid())
  examSessionId String
  title         String
  description   String?
  status        ExamPaperStatus @default(DRAFT)
  totalPoints   Int             @default(0)
  shuffleQuestions Boolean      @default(true)
  shuffleOptions   Boolean      @default(true)
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  examSession   ExamSession     @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  sections      ExamPaperSection[]
  items         ExamPaperItem[]
  attempts      ExamAttempt[]

  @@index([examSessionId, status])
}

model ExamPaperSection {
  id        String   @id @default(cuid())
  paperId   String
  title     String
  order     Int      @default(0)

  paper     ExamPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  items     ExamPaperItem[]

  @@index([paperId, order])
}

model ExamPaperItem {
  id         String   @id @default(cuid())
  paperId    String
  sectionId  String?
  questionId String
  order      Int      @default(0)
  points     Int      @default(1)
  required   Boolean  @default(true)
  scoringPolicy Json?

  paper      ExamPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  section    ExamPaperSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([paperId, questionId])
  @@index([paperId, order])
  @@index([questionId])
}

model ExamAttempt {
  id             String            @id @default(cuid())
  examSessionId  String
  applicationId  String
  userId         String
  paperId        String
  status         ExamAttemptStatus @default(IN_PROGRESS)
  startedAt      DateTime          @default(now())
  expiresAt      DateTime
  submittedAt    DateTime?
  lastHeartbeatAt DateTime?
  questionOrder  String[]
  warningCount   Int               @default(0)
  invalidatedReason String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  examSession    ExamSession       @relation(fields: [examSessionId], references: [id])
  application    ExamApplication   @relation(fields: [applicationId], references: [id])
  user           User              @relation(fields: [userId], references: [id])
  paper          ExamPaper         @relation(fields: [paperId], references: [id])
  answers        ExamAnswer[]
  proctorEvents  ExamProctorEvent[]
  proctorSnapshots ExamProctorSnapshot[]
  result         ExamResult?

  @@unique([applicationId])
  @@index([examSessionId, status])
  @@index([userId, status])
  @@index([expiresAt])
}

model ExamAnswer {
  id              String           @id @default(cuid())
  attemptId       String
  questionId      String
  selectedOptionIds String[]
  textAnswer      String?
  fileUrl         String?
  fileName        String?
  answerJson      Json?
  questionSnapshot Json?
  optionsSnapshot  Json?
  pointsSnapshot   Int             @default(0)
  score           Int?
  feedback        String?
  status          ExamAnswerStatus @default(DRAFT)
  savedAt         DateTime         @default(now())
  submittedAt     DateTime?
  gradedAt        DateTime?
  gradedById      String?

  attempt         ExamAttempt      @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        Question         @relation(fields: [questionId], references: [id])
  gradedBy        User?            @relation("ExamAnswerGradedBy", fields: [gradedById], references: [id])

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([status])
}

model ExamResult {
  id            String           @id @default(cuid())
  attemptId     String           @unique
  totalScore    Int              @default(0)
  maxScore      Int              @default(0)
  percentage    Float            @default(0)
  status        ExamResultStatus @default(PENDING)
  feedback      String?
  publishedAt   DateTime?
  publishedById String?
  emailSentAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  attempt       ExamAttempt      @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  publishedBy   User?            @relation("ExamResultPublishedBy", fields: [publishedById], references: [id])

  @@index([status])
  @@index([publishedAt])
}

model ExamProctorEvent {
  id          String               @id @default(cuid())
  attemptId   String
  type        ExamProctorEventType
  payload     Json?
  occurredAt  DateTime             @default(now())

  attempt     ExamAttempt          @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId, occurredAt])
  @@index([type, occurredAt])
}

model ExamProctorSnapshot {
  id          String   @id @default(cuid())
  attemptId   String
  fileUrl     String
  fileName    String?
  mimeType    String?
  capturedAt  DateTime @default(now())

  attempt     ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId, capturedAt])
}

// ─── 결제 ────────────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  userId        String
  targetType    PaymentTarget
  targetId      String
  orderNo       String        @unique
  amount        Int
  currency      String        @default("KRW")
  baseAmount    Int           @default(0)
  discountAmount Int          @default(0)
  finalAmount   Int           @default(0)
  pricePolicyVersion Int      @default(1)
  paymentStatus PaymentStatus @default(PENDING)
  pgProvider    String?
  pgTxId        String?
  paidAt        DateTime?
  cancelledAt   DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])

  @@index([userId, paymentStatus])
  @@index([orderNo])
}

// ─── 온라인 교재 ─────────────────────────────────────────────────────────────

model Textbook {
  id            String         @id @default(cuid())
  title         String
  description   String?
  coverImageUrl String?
  s3Key         String?
  localPath     String?
  totalPages    Int?
  price         Int            @default(0)
  currency      String         @default("KRW")
  basePrice     Int            @default(0)
  salePrice     Int?
  discountType  DiscountType   @default(NONE)
  discountValue Int            @default(0)
  priceValidFrom DateTime?
  priceValidUntil DateTime?
  pricePolicyVersion Int       @default(1)
  isStandalone  Boolean        @default(false)
  status        TextbookStatus @default(DRAFT)
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  createdBy     User           @relation("TextbookCreator", fields: [createdById], references: [id])
  courseLinks   CourseTextbook[]
  accesses      TextbookAccess[]
  viewLogs      TextbookViewLog[]
}

model CourseTextbook {
  id                 String  @id @default(cuid())
  courseId           String
  textbookId         String
  sortOrder          Int     @default(0)
  autoGrantOnEnroll  Boolean @default(true)

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  textbook  Textbook @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@unique([courseId, textbookId])
}

model TextbookAccess {
  id          String            @id @default(cuid())
  userId      String
  textbookId  String
  grantedBy   TextbookGrantedBy
  sourceId    String?
  expiresAt   DateTime?
  grantedAt   DateTime          @default(now())
  revokedAt   DateTime?

  user        User     @relation(fields: [userId], references: [id])
  textbook    Textbook @relation(fields: [textbookId], references: [id])

  @@unique([userId, textbookId])
  @@index([userId, textbookId])
}

model TextbookViewLog {
  id          String   @id @default(cuid())
  userId      String
  textbookId  String
  pageNumber  Int
  viewedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  textbook    Textbook @relation(fields: [textbookId], references: [id])

  @@index([userId, textbookId])
  @@index([textbookId, viewedAt])
}

model BookVoucherCampaign {
  id          String   @id @default(cuid())
  name        String
  provider    String   @default("BUKIO")
  courseId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  codes       BookVoucherCode[]
  grants      BookVoucherGrant[]

  @@index([courseId, isActive])
}

model BookVoucherCode {
  id          String                @id @default(cuid())
  campaignId  String
  code        String                @unique
  status      BookVoucherCodeStatus @default(AVAILABLE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  campaign    BookVoucherCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  grant       BookVoucherGrant?

  @@index([campaignId, status])
}

model BookVoucherGrant {
  id          String   @id @default(cuid())
  campaignId  String
  codeId      String   @unique
  userId      String
  courseId    String?
  enrollmentId String?
  grantedAt   DateTime @default(now())
  usedAt      DateTime?

  campaign    BookVoucherCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  code        BookVoucherCode     @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@unique([userId, campaignId])
  @@index([userId, grantedAt])
}

// ─── 공지 / FAQ / Q&A / 문의 ────────────────────────────────────────────────

model Notice {
  id          String     @id @default(cuid())
  scopeType   NoticeScope @default(GLOBAL)
  scopeId     String?
  title       String
  content     String
  isPinned    Boolean    @default(false)
  isPublished Boolean    @default(false)
  publishedAt DateTime?
  scheduledAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  course      Course?    @relation(fields: [scopeId], references: [id])
  attachments NoticeAttachment[]

  @@index([scopeType, scopeId, isPinned])
}

model NoticeAttachment {
  id         String   @id @default(cuid())
  noticeId   String
  storageKey String?
  localPath  String?
  fileName   String
  mimeType   String
  fileSize   Int
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  notice     Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@index([noticeId, sortOrder])
}

model Faq {
  id         String   @id @default(cuid())
  category   String
  question   String
  answer     String
  sortOrder  Int      @default(0)
  isPublished Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model QnaQuestion {
  id         String      @id @default(cuid())
  courseId   String
  userId     String
  assignedInstructorId String
  title      String
  content    String
  status     QnaQuestionStatus @default(OPEN)
  isPrivate  Boolean     @default(false)
  isClosed   Boolean     @default(false)
  answeredAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  course     Course      @relation(fields: [courseId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  assignedInstructor User @relation("QnaAssignedInstructor", fields: [assignedInstructorId], references: [id])
  answers    QnaAnswer[]

  @@index([courseId, createdAt])
  @@index([assignedInstructorId, status, createdAt])
}

model QnaAnswer {
  id         String   @id @default(cuid())
  questionId String
  userId     String
  content    String
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())

  question   QnaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id])
}

model Inquiry {
  id         String        @id @default(cuid())
  userId     String
  category   String
  title      String
  content    String
  fileUrl    String?
  status     InquiryStatus @default(OPEN)
  response   String?
  respondedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user       User          @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

// ─── 강사 게시판 ─────────────────────────────────────────────────────────────

model InstructorPost {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  content     String
  isPinned    Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([isPinned, createdAt])
}

// ─── 시스템 설정 / 감사 로그 ──────────────────────────────────────────────────

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  targetType String?
  targetId   String?
  detail     Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model PriceHistory {
  id                 String          @id @default(cuid())
  targetType         PriceTargetType
  targetId           String
  currency           String          @default("KRW")
  oldBasePrice       Int?
  oldSalePrice       Int?
  oldDiscountType    DiscountType?
  oldDiscountValue   Int?
  oldValidFrom       DateTime?
  oldValidUntil      DateTime?
  oldPolicyVersion   Int?
  newBasePrice       Int?
  newSalePrice       Int?
  newDiscountType    DiscountType?
  newDiscountValue   Int?
  newValidFrom       DateTime?
  newValidUntil      DateTime?
  newPolicyVersion   Int?
  reason             String?
  changedById        String?
  createdAt          DateTime        @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([changedById, createdAt])
}

model PageView {
  id         String   @id @default(cuid())
  path       String
  sessionId  String
  userId     String?
  userAgent  String?
  browser    String?
  deviceType String?
  referrer   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([sessionId, createdAt])
}

// ─── 큐미 RAG: 챗봇 지식 문서(임베딩 포함) ────────────────────────────────────
model ChatbotDocument {
  id          String                       @id @default(cuid())
  title       String
  category    String
  url         String                       @default("")
  content     String
  keywords    String[]                     @default([])
  roles       String[]                     @default(["public"])
  pose        String                       @default("explaining")
  suggestions String[]                     @default([])
  enabled     Boolean                      @default(true)
  // pgvector(1536) — OpenAI text-embedding-3-small. 읽기/쓰기는 raw SQL 사용.
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([enabled])
  @@map("chatbot_documents")
}

// ─── 교육 운영(Training Program) ─────────────────────────────────────────────

// 개인별 '교육 운영' 기능 사용 권한. 역할(Role)과 무관하게 관리자가 부여/회수한다.
// OPERATOR/SUPER_ADMIN 은 그랜트 없이 통과하므로 행이 필요 없다.
model TrainingPermission {
  id          String   @id @default(cuid())
  userId      String   @unique
  grantedById String?
  grantedAt   DateTime @default(now())
  note        String?

  user      User  @relation("TrainingPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("TrainingPermissionGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
}

model TrainingProgram {
  id          String                @id @default(cuid())
  title       String
  description String?
  courseId    String? // 기존 플랫폼 강좌와 선택적 연결
  ownerId     String // 생성한(권한 부여받은) 사용자
  location    String?
  capacity    Int?
  startDate   DateTime              @db.Date
  endDate     DateTime              @db.Date
  status      TrainingProgramStatus @default(DRAFT)
  // 게시용 보기 전용 공유 토큰. 값이 있으면 공개 페이지(/training-plan/{token})와
  // 메인 페이지 일정 위젯에 노출된다. 해제 시 null.
  shareToken  String?               @unique
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  course       Course?               @relation(fields: [courseId], references: [id], onDelete: SetNull)
  owner        User                  @relation("TrainingProgramOwner", fields: [ownerId], references: [id])
  sessions     TrainingSession[]
  participants TrainingParticipant[]
  certificates TrainingCertificate[]

  @@index([ownerId, status])
  @@index([startDate, endDate])
}

model TrainingSession {
  id        String   @id @default(cuid())
  programId String
  sessionNo Int // 회차 번호(1부터, 서비스에서 자동 부여)
  date      DateTime @db.Date
  // KST 로컬 시각 문자열("HH:mm") — TZ 변환 없이 그대로 저장/표시한다.
  startTime String
  endTime   String
  topic     String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program     TrainingProgram      @relation(fields: [programId], references: [id], onDelete: Cascade)
  attendances TrainingAttendance[]

  @@unique([programId, sessionNo])
  @@index([programId, date])
  @@index([date])
}

model TrainingParticipant {
  id          String                    @id @default(cuid())
  programId   String
  userId      String? // 플랫폼 회원인 경우만
  // 등록 시점 스냅샷(회원도 복사) — 이후 회원 정보 변경과 무관하게 명단/수료증이 유지된다.
  name        String
  phone       String?
  email       String?
  affiliation String?
  status      TrainingParticipantStatus @default(REGISTERED)
  note        String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  program      TrainingProgram       @relation(fields: [programId], references: [id], onDelete: Cascade)
  user         User?                 @relation("TrainingParticipantUser", fields: [userId], references: [id], onDelete: SetNull)
  attendances  TrainingAttendance[]
  certificates TrainingCertificate[]

  // 회원 중복 등록 방지. userId NULL(비회원)은 PG 특성상 중복 허용 → 서비스에서 email/phone 검사
  @@unique([programId, userId])
  @@index([programId, status])
}

model TrainingAttendance {
  id            String                   @id @default(cuid())
  sessionId     String
  participantId String
  status        TrainingAttendanceStatus @default(PRESENT)
  note          String?
  checkedById   String?
  checkedAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  session     TrainingSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant TrainingParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  checkedBy   User?               @relation("TrainingAttendanceCheckedBy", fields: [checkedById], references: [id], onDelete: SetNull)

  @@unique([sessionId, participantId])
  @@index([participantId])
}

model TrainingCertificate {
  id            String                    @id @default(cuid())
  certificateNo String                    @unique
  programId     String
  participantId String
  // 발급 시점 스냅샷 — 이후 프로그램/참가자 수정과 무관하게 수료증 내용 불변
  participantName String
  programTitle    String
  attendanceRate  Float?
  status         TrainingCertificateStatus @default(ISSUED)
  issuedAt       DateTime                  @default(now())
  issuedById     String?
  revokedAt      DateTime?
  revokeReason   String?
  reissuedFromId String?                   @unique // 재발급 체인(구 수료증 → 신 수료증)

  // program/participant 는 onDelete 기본(Restrict) — 수료증이 있는 대상의 삭제를 DB 레벨에서 차단
  program      TrainingProgram      @relation(fields: [programId], references: [id])
  participant  TrainingParticipant  @relation(fields: [participantId], references: [id])
  issuedBy     User?                @relation("TrainingCertificateIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  reissuedFrom TrainingCertificate? @relation("CertificateReissue", fields: [reissuedFromId], references: [id])
  reissuedTo   TrainingCertificate? @relation("CertificateReissue")

  @@index([participantId, status])
  @@index([programId])
}

// 연도별 수료증 일련번호 카운터. $transaction 내 upsert increment 로 동시 발급에 안전하다.
model TrainingCertificateCounter {
  year    Int @id
  lastSeq Int @default(0)
}
