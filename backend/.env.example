# ─── 서버 ────────────────────────────────────────────────────
NODE_ENV=production
PORT=4400

# ─── 데이터베이스 (Render PostgreSQL) ────────────────────────
# Render 대시보드 > PostgreSQL > Internal Connection String 복사
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ─── Redis (Render Key Value / Upstash) ──────────────────────
# 현재 코드에서 미사용. Bull Queue 활성화 시 필요.
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
VIEWER_TOKEN_SECRET=your-viewer-token-secret

# ─── CORS ────────────────────────────────────────────────────
# 콤마로 여러 도메인 구분 가능
FRONTEND_URL=https://academiq.vercel.app,https://academiq.co.kr

# ─── PDF 교재 저장 경로 ──────────────────────────────────────
# Render Disk 마운트 경로 (로컬: backend/static/textbooks)
TEXTBOOK_STORAGE_PATH=/data/textbooks

# ─── S3 호환 스토리지 (Cloudflare R2 포함) ──────────────────
# 배포(Render): R2 권장
# 로컬 개발: localPath(backend/static/textbooks) 우선 사용
# 표준 키(S3_*)를 우선 사용하고 AWS_*는 fallback으로 동작
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=academiq-private
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── AWS (기존 호환값, 미디어/CloudFront) ───────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_ENDPOINT=
AWS_S3_BUCKET_PRIVATE=academiq-private
AWS_S3_BUCKET_PUBLIC=academiq-public
AWS_CLOUDFRONT_DOMAIN=d1234567890.cloudfront.net
AWS_CLOUDFRONT_KEY_PAIR_ID=APKAIEXAMPLE
# CloudFront 서명 Private Key (Base64 인코딩)
AWS_CLOUDFRONT_PRIVATE_KEY=

# ─── 결제 (PortOne / 아임포트) ───────────────────────────────
PORTONE_API_KEY=
PORTONE_API_SECRET=
PORTONE_IMP_CODE=imp00000000
PAYMENT_ALERT_WEBHOOK_URL=

# ─── 이메일 (AWS SES) ─────────────────────────────────────────
AWS_SES_FROM_EMAIL=noreply@academiq.co.kr

# ─── SMS/카카오 알림 (Solapi) ─────────────────────────────────
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# ─── 사이트 URL (seed 스크립트용) ────────────────────────────
NEXT_PUBLIC_SITE_URL=https://academiq.co.kr
